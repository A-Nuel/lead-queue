# Supabase — Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SerpAPI — https://serpapi.com/manage-api-key
SERPAPI_KEY=your-serpapi-key

# Optional — Meta Ad Library (Graph API access token from a Meta developer app)
# If left unset, ad-spend detection is skipped (running_ads always false)
META_ACCESS_TOKEN=

# Optional — protects the cron endpoint from being called by randoms
CRON_SECRET=pick-a-random-string
