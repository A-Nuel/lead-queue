# Supabase — Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SerpAPI — https://serpapi.com/manage-api-key
SERPAPI_KEY=your-serpapi-key

# Optional — Meta Ad Library (Graph API access token from a Meta developer app)
# If left unset, ad-spend detection is skipped (running_ads always false)
META_ACCESS_TOKEN=

# Optional — Twilio Lookup, used only for US/Canada numbers (where mobile vs
# landline can't be told apart from the number itself, unlike UK/AU/UAE).
# ~$0.005/lookup, only called when the free heuristic can't classify.
# Get these from twilio.com/console (Account SID + Auth Token)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional — DeepSeek API, used to AI-review website quality instead of
# relying purely on heuristics (which produce false positives/negatives).
# ~$0.14 per million input tokens — reviewing 1000 sites costs cents.
# Get a key at platform.deepseek.com (5M free tokens on signup, 30 days)
DEEPSEEK_API_KEY=

# Optional — protects the cron endpoint from being called by randoms
CRON_SECRET=pick-a-random-string
